{
  "name": "jlpt-lookup",
  "version": "1.2.0",
  "description": "日语划词查询工具 - JLPT释义、假名、语法分析",
  "main": "src/main/main.js",
  "author": "JLPT Lookup",
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir",
    "release": "electron-builder --win --publish always",
    "generate-icon": "node scripts/generate-icon.js",
    "download-dict": "node scripts/download-jmdict.js",
    "import-dict": "node scripts/import-jmdict.js",
    "import-jlpt": "node scripts/import-jlpt.js",
    "download-chinese": "node scripts/download-jmdict-all.js",
    "import-chinese": "node scripts/import-chinese.js",
    "add-chinese": "node scripts/add-chinese-common.js",
    "test-core": "node scripts/test-core.js",
    "test-full": "node scripts/test-full.js",
    "test-llm": "node scripts/test-llm.js"
  },
  "keywords": [
    "japanese",
    "jlpt",
    "dictionary",
    "popup"
  ],
  "build": {
    "appId": "com.jlpt.lookup",
    "productName": "JLPT Lookup",
    "copyright": "Copyright © 2025",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "data/dictionary.db",
      "data/app-config.json",
      "!data/llm-config.json",
      "!data/jmdict-*.json",
      "!data/jmdict-*.zip",
      "!data/jmdict-*.tgz",
      "!node_modules/**/*.md",
      "!node_modules/**/*.ts",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/example/**",
      "!node_modules/**/examples/**"
    ],
    "extraResources": [
      {
        "from": "data/dictionary.db",
        "to": "data/dictionary.db"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "publish": {
      "provider": "github",
      "owner": "yuanyuana1",
      "repo": "jlpt-lookup",
      "releaseType": "release"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JLPT Lookup"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/kuromoji/dict/**",
      "node_modules/sql.js/dist/**",
      "data/**"
    ]
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "kuromoji": "^0.1.2",
    "openai": "^6.37.0",
    "sql.js": "^1.12.0"
  }
}
